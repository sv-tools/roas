{
  "Pet": {
    "type": "object",
    "required": [
      "id",
      "name",
      "owner"
    ],
    "properties": {
      "id": {
        "type": "integer",
        "format": "int64"
      },
      "name": {
        "type": "string"
      },
      "owner": {
        "$ref": "#/Owner"
      }
    }
  },
  "Owner": {
    "type": "object",
    "required": [
      "name"
    ],
    "properties": {
      "name": {
        "type": "string"
      }
    }
  }
}
