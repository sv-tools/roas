{
  "openapi": "3.2.0",
  "info": {
    "version": "1.0.0",
    "title": "Swagger Petstore (cross-ref edition)",
    "license": {
      "name": "MIT"
    }
  },
  "paths": {
    "/pets/{petId}": {
      "get": {
        "summary": "Info for a specific pet",
        "operationId": "showPetById",
        "tags": [
          "pets"
        ],
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "required": true,
            "description": "The id of the pet to retrieve",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Expected response to a valid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "__EXTERNAL_PETS_URL__#/Pet"
                }
              }
            }
          }
        }
      }
    }
  }
}
